{
  "name": "mottbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram-first Codex subscription bot inspired by OpenClaw's openai-codex provider path.",
  "bin": {
    "mottbot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts start",
    "start": "node dist/index.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "health": "tsx src/index.ts health",
    "auth:login": "tsx src/index.ts auth login",
    "auth:import-cli": "tsx src/index.ts auth import-cli",
    "db:migrate": "tsx src/index.ts db migrate"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.5.0",
    "grammy": "^1.38.3",
    "open": "^10.2.0",
    "pino": "^9.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.15",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
