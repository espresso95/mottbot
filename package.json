{
  "name": "mottbot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "description": "Telegram-first Codex subscription bot for the subscription-backed openai-codex provider path.",
  "bin": {
    "mottbot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "dev": "tsx watch src/index.ts start",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" \"vitest.config.ts\"",
    "tsdoc:audit": "tsx src/tools/tsdoc-audit.ts",
    "docs:check": "tsx src/tools/docs-link-check.ts",
    "deps:cycles": "madge --circular --json --extensions ts --ts-config tsconfig.eslint.json src scripts test vitest.config.ts",
    "knip": "knip --include files,dependencies,unlisted,binaries,unresolved --no-progress",
    "verify": "corepack pnpm check && corepack pnpm lint && corepack pnpm format:check && corepack pnpm tsdoc:audit -- --strict && corepack pnpm docs:check && corepack pnpm deps:cycles && corepack pnpm knip && corepack pnpm test:coverage",
    "start": "node dist/index.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "health": "tsx src/index.ts health",
    "auth:login": "tsx src/index.ts auth login",
    "auth:import-cli": "tsx src/index.ts auth import-cli",
    "backup": "tsx src/index.ts backup",
    "db:migrate": "tsx src/index.ts db migrate",
    "db:prune": "tsx src/index.ts db prune --dry-run",
    "logs": "tsx src/index.ts logs",
    "service": "tsx src/index.ts service",
    "restart": "tsx src/index.ts restart",
    "smoke:preflight": "tsx scripts/smoke/live-smoke-preflight.ts",
    "smoke:telegram-user": "tsx scripts/smoke/live-telegram-user-smoke.ts",
    "smoke:dashboard": "tsx scripts/smoke/dashboard-smoke.ts",
    "smoke:local-tools": "tsx scripts/smoke/local-tool-validation-suite.ts",
    "smoke:github-write": "tsx scripts/smoke/github-write-validation-suite.ts",
    "smoke:lane": "tsx scripts/smoke/smoke-lane.ts",
    "smoke:suite": "tsx scripts/smoke/live-validation-suite.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "better-sqlite3": "^11.10.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.5.0",
    "grammy": "^1.38.3",
    "open": "^10.2.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.7.0",
    "punycode": "^2.3.1",
    "telegram": "^2.26.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.15",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.5.0",
    "knip": "^6.7.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "bufferutil",
      "es5-ext",
      "utf-8-validate"
    ],
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "patchedDependencies": {
      "whatwg-url@5.0.0": "patches/whatwg-url@5.0.0.patch",
      "tr46@0.0.3": "patches/tr46@0.0.3.patch"
    }
  }
}
