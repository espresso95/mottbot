# Runtime config file location override (optional)
MOTTBOT_CONFIG_PATH=./mottbot.config.json

# Tool delegated access tokens referenced by mottbot.config.json
MOTTBOT_MICROSOFT_TODO_ACCESS_TOKEN=
MOTTBOT_GOOGLE_DRIVE_ACCESS_TOKEN=

# Smoke scripts are operator-run helpers, not runtime requirements.
# Keep these unset by default and export only what you need per command.
# See docs/live-smoke-tests.md for the full variable matrix.

# Common Telegram user-smoke credentials (required for MTProto user smoke)
MOTTBOT_LIVE_BOT_USERNAME=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional command-specific overrides (examples)
MOTTBOT_LIVE_VALIDATION_DRY_RUN=true
MOTTBOT_GITHUB_WRITE_SMOKE_DRY_RUN=true
MOTTBOT_DASHBOARD_SMOKE_PORT=
