# Runtime config file location override (optional)
MOTTBOT_CONFIG_PATH=./mottbot.config.json

# Tool delegated access tokens referenced by mottbot.config.json
MOTTBOT_MICROSOFT_TODO_ACCESS_TOKEN=
MOTTBOT_GOOGLE_DRIVE_ACCESS_TOKEN=

# Live smoke and validation toggles (optional; used by smoke:* scripts)
MOTTBOT_LIVE_SMOKE_ENABLED=false
MOTTBOT_LIVE_TEST_CHAT_ID=
MOTTBOT_LIVE_TEST_MESSAGE=
MOTTBOT_DASHBOARD_SMOKE_PORT=
MOTTBOT_USER_SMOKE_ENABLED=false
MOTTBOT_LIVE_BOT_USERNAME=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=
TELEGRAM_LOGIN_CODE=
TELEGRAM_2FA_PASSWORD=
TELEGRAM_USER_SESSION=
MOTTBOT_USER_SMOKE_TARGET=
MOTTBOT_USER_SMOKE_MESSAGE=
MOTTBOT_USER_SMOKE_FILE_PATH=
MOTTBOT_USER_SMOKE_FORCE_DOCUMENT=false
MOTTBOT_USER_SMOKE_REPLY_TO_LATEST_BOT_MESSAGE=false
MOTTBOT_USER_SMOKE_SESSION_PATH=
MOTTBOT_USER_SMOKE_TIMEOUT_MS=
MOTTBOT_USER_SMOKE_POLL_INTERVAL_MS=
MOTTBOT_USER_SMOKE_STABLE_REPLY_MS=
MOTTBOT_USER_SMOKE_WAIT_FOR_REPLY=true

MOTTBOT_LIVE_VALIDATION_ENABLED=false
MOTTBOT_LIVE_VALIDATION_DRY_RUN=false
MOTTBOT_LIVE_VALIDATION_SCENARIOS=
MOTTBOT_LIVE_VALIDATION_REQUIRE_USER_SMOKE=false
MOTTBOT_LIVE_VALIDATION_INCLUDE_USER_SMOKE=true
MOTTBOT_LIVE_VALIDATION_PRIVATE_TARGET=
MOTTBOT_LIVE_VALIDATION_PRIVATE_MESSAGE=
MOTTBOT_LIVE_VALIDATION_REPLY_MESSAGE=
MOTTBOT_LIVE_VALIDATION_GROUP_TARGET=
MOTTBOT_LIVE_VALIDATION_GROUP_MESSAGE=
MOTTBOT_LIVE_VALIDATION_FILE_PATHS=
MOTTBOT_LIVE_VALIDATION_FILE_TARGET=
MOTTBOT_LIVE_VALIDATION_FILE_MESSAGE=
MOTTBOT_LIVE_VALIDATION_FORCE_DOCUMENT=false

MOTTBOT_GITHUB_WRITE_SMOKE_ENABLED=false
MOTTBOT_GITHUB_WRITE_SMOKE_DRY_RUN=true
MOTTBOT_GITHUB_WRITE_SMOKE_CONFIRM=
MOTTBOT_GITHUB_WRITE_SMOKE_REPOSITORY=
MOTTBOT_GITHUB_WRITE_SMOKE_TITLE=
MOTTBOT_GITHUB_WRITE_SMOKE_BODY=
MOTTBOT_GITHUB_WRITE_SMOKE_LABELS=
MOTTBOT_GITHUB_WRITE_SMOKE_PR_NUMBER=
